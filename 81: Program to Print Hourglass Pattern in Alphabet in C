#include <stdio.h>

int main() {
    int n = 5;

    for (int i = 0; i < 2 * n - 1; i++) {

        int comp;
        if (i < n) comp = 2 * (n - i) - 1;
        else comp = 2 * (i - n + 1) + 1;

        for (int j = 0; j < 2 * n - comp - 1; j++)
            printf(" ");

        for (int k = 0; k < comp; k++)
            printf("%c ", k + 'A');
        printf("\n");
    }
    return 0;
}
